{
	"_docs":           "https://developer.wordpress.org/block-editor/reference-guides/block-api/block-metadata/",
	"$schema":         "https://schemas.wp.org/trunk/block.json",
	"apiVersion":      3,
	"name":            "{{ app_short_name }}/{{ block_dir_name }}",
	"title":           "{{ root_namespace }} Block: {{ name }}",
	"description":     "{{ root_namespace }} Block: {{ name }} - description...",
	"version":         "1.0.0",
	"icon":            "block-default",
	"category":        "text",
	"textdomain":      "{{ text_domain }}",
	"keywords":        [],
	"attributes":      {
		"title": {
			"type": "string"
		}
	},
	"providesContext": {},
	"usesContext":     [],
	"selectors":       {},
	"supports":        {},
	"styles":          [],
	"example":         {},
	"variations":      [],
	"script":          "file:./script.js",
	"viewScript":      "file:./view.js",
	"editorScript":    "file:./index.js",
	"style":           "file:./style.css",
	"viewStyle":       "file:./view.css",
	"editorStyle":     "file:./index.css",
	"render":          "file:./render.blade.php"
}
//	public $column_name             = '{{ name }}';
	public $column_title            = '{{ name }}';
	public $column_add_priority     = 9999;
	public $column_content_priority = 9999;
	public $post_types              = ['post', 'wpsp_content'];
//	public $before_column           = [];
//	public $after_column            = [];
